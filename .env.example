# z.ai exposes an Anthropic-compatible endpoint. The Claude Agent SDK
# spawns Claude Code under the hood, which honours these two env vars.
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_zai_api_key_here

# Optional: pin a specific GLM model. Leave unset to use z.ai's default
# Sonnet/Opus -> GLM mapping (recommended).
# ANTHROPIC_MODEL=glm-4.6

# Required: imarouter API key (sk-...). One key drives both modalities — the
# generate_image tool calls gpt-image-2 and generate_video calls seedance-2.0-fast,
# both via https://api.imarouter.com.
IMAROUTER_API_KEY=sk-your_imarouter_key_here

# Optional: override the imarouter base URL (e.g. for staging).
# IMAROUTER_BASE_URL=https://api.imarouter.com

# Optional: pin specific model ids. Defaults are gpt-image-2 and seedance-2.0-fast.
# Other image options: gemini-3-pro-image-preview, doubao-seedream-*, wan2.7-*.
# Other video options: seedance-2.0, seedance-2.0-cn, wan2.6-i2v, MiniMax-Hailuo-2.3.
# IMAROUTER_IMAGE_MODEL=gpt-image-2
# IMAROUTER_VIDEO_MODEL=seedance-2.0-fast

# Optional: per-kind poll timeouts (ms). Defaults: images 3 min, videos 12 min.
# Bump video timeout if 6× concurrent Seedance batches keep hitting the limit
# (queueing on imarouter's side can push wall-clock past the default).
# IMAROUTER_IMAGE_TIMEOUT_MS=180000
# IMAROUTER_VIDEO_TIMEOUT_MS=720000
# IMAROUTER_POLL_INTERVAL_MS=5000

# Required: API key for the Butterbase MCP server (https://api.butterbase.ai/mcp).
# Generate one in the Butterbase dashboard. Keys are prefixed with `bb_sk_` and
# are sent as `Authorization: Bearer ...` to the MCP endpoint. Used at deploy time
# and for persisting final assets (imarouter URLs expire ~30 days after creation).
BUTTERBASE_API_KEY=bb_sk_your_key_here
BUTTERBASE_APP_ID=app_your_app_id_here

# Optional: standalone Node worker for the static frontend.
PREOP_API_HOST=127.0.0.1
PREOP_API_PORT=8787
PREOP_WEB_ORIGIN=http://localhost:3000
PREOP_MAX_BUDGET_USD=8

# web/.env.local should expose the worker base URL to the static Next frontend:
# NEXT_PUBLIC_PREOP_API_URL=http://127.0.0.1:8787
