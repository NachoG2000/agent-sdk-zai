# z.ai exposes an Anthropic-compatible endpoint. The Claude Agent SDK
# spawns Claude Code under the hood, which honours these two env vars.
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_zai_api_key_here

# Optional: pin a specific GLM model. Leave unset to use z.ai's default
# Sonnet/Opus -> GLM mapping (recommended).
# ANTHROPIC_MODEL=glm-4.6

# Optional: bearer token for the Higgsfield MCP server (https://mcp.higgsfield.ai/mcp).
# Higgsfield's MCP normally authenticates via OAuth in the Claude Desktop UI.
# In a headless SDK run there is no browser to complete that flow, so if you can
# capture a session bearer token from a logged-in Claude Desktop / browser session,
# put it here and it will be sent as `Authorization: Bearer ...`.
# HIGGSFIELD_TOKEN=

# Required: API key for the Butterbase MCP server (https://api.butterbase.ai/mcp).
# Generate one in the Butterbase dashboard. Keys are prefixed with `bb_sk_` and
# are sent as `Authorization: Bearer ...` to the MCP endpoint.
BUTTERBASE_API_KEY=bb_sk_your_key_here
